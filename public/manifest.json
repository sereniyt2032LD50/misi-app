{
  "manifest_version": 3,
  "name": "Aegis: Emotion-Aware Safety Assistant",
  "version": "1.0.0",
  "description": "Real-time posture correction, fall detection, and emotion-aware voice assistant.",
  "permissions": [
    "sidePanel",
    "storage",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Aegis"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
